# gruenbeck2lox environment variables
# Copy this file to .env and adjust values as needed.
# All variables can also be set via docker-compose environment section.

# Absolute path to the data directory (SQLite + config.yaml).
# Default (inside Docker): /app/data
# GRUENBECK2LOX_DATA_DIR=/app/data

# Logging level: DEBUG | INFO | WARNING | ERROR
# GRUENBECK2LOX_LOG_LEVEL=INFO

# Fernet encryption key for Loxone passwords stored in SQLite.
# If empty, a key is auto-generated and stored in DATA_DIR/.secret.
# Generate a key with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# GRUENBECK2LOX_SECRET_KEY=

# Bind host and port for the HTTP API / Web-UI.
# GRUENBECK2LOX_HOST=0.0.0.0
# GRUENBECK2LOX_PORT=8080
